<Window x:Class="CortexSpeed.Presentation.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:CortexSpeed.Presentation.WPF.ViewModels"
        xmlns:conv="clr-namespace:CortexSpeed.Presentation.WPF.Converters"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        mc:Ignorable="d"
        Title="Cortex Speed" Height="720" Width="1100" MinHeight="550" MinWidth="800"
        Background="{StaticResource AppBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        FontFamily="Segoe UI, Inter, Arial">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="36" GlassFrameThickness="0" CornerRadius="12" ResizeBorderThickness="6"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <conv:CategoryToIconConverter x:Key="CategoryIcon"/>
        <conv:DownloadStateConverter x:Key="StateText"/>
        <conv:BoolToVisibilityConverter x:Key="BoolVis"/>
    </Window.Resources>

    <Border CornerRadius="12" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" Background="{StaticResource AppBackgroundBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="36"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ═══ TITLE BAR ═══ -->
            <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" CornerRadius="12,12,0,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0,0,0">
                        <TextBlock Text="⚡" FontSize="15" VerticalAlignment="Center" Margin="0,0,8,0"/>
                        <TextBlock Text="Cortex Speed" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" FontSize="12.5" VerticalAlignment="Center"/>
                        <TextBlock Text="v2.0" Foreground="{StaticResource TextMutedBrush}" FontSize="10" VerticalAlignment="Center" Margin="6,1,0,0"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Content="─" Style="{StaticResource WindowChromeButton}" Click="MinimizeClick"/>
                        <Button Content="□" Style="{StaticResource WindowChromeButton}" Click="MaximizeClick"/>
                        <Button Content="✕" Style="{StaticResource WindowCloseButton}" Click="CloseClick"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══ MAIN CONTENT ═══ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="220"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ═══ SIDEBAR ═══ -->
                <Border Grid.Column="0" Background="{StaticResource SidebarGradientBrush}" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,1,0">
                    <Grid>
                        <Grid.RowDefinitions>
                            <RowDefinition Height="Auto"/>
                            <RowDefinition Height="*"/>
                            <RowDefinition Height="Auto"/>
                        </Grid.RowDefinitions>

                        <!-- Add Download Button -->
                        <Button Grid.Row="0" Style="{StaticResource PrimaryButtonStyle}" Margin="12,16,12,8" Command="{Binding OpenAddDialogCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="＋" FontSize="16" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                <TextBlock Text="Add Download" FontSize="13" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>

                        <!-- Nav Items -->
                        <ListBox Grid.Row="1" ItemsSource="{Binding SidebarItems}" SelectedItem="{Binding SelectedCategory}" 
                                 Background="Transparent" BorderThickness="0" Margin="0,8,0,0"
                                 ItemContainerStyle="{StaticResource SidebarItemStyle}"/>

                        <!-- Bottom Actions -->
                        <StackPanel Grid.Row="2" Margin="12,8,12,16">
                            <Button Content="⏸ Pause All" Style="{StaticResource GhostButtonStyle}" HorizontalAlignment="Stretch" Margin="0,2" Command="{Binding PauseAllCommand}"/>
                            <Button Content="▶ Resume All" Style="{StaticResource GhostButtonStyle}" HorizontalAlignment="Stretch" Margin="0,2" Command="{Binding ResumeAllCommand}"/>
                            <Button Content="🗑 Clear Done" Style="{StaticResource GhostButtonStyle}" HorizontalAlignment="Stretch" Margin="0,2" Command="{Binding ClearCompletedCommand}"/>
                            <Separator Background="{StaticResource BorderSubtleBrush}" Margin="0,8"/>
                            <Button Content="⚙ Settings" Style="{StaticResource GhostButtonStyle}" HorizontalAlignment="Stretch" Command="{Binding OpenSettingsCommand}"/>
                        </StackPanel>
                    </Grid>
                </Border>

                <!-- ═══ RIGHT PANEL ═══ -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- Quick URL Bar -->
                    <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" Padding="16,12" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding UrlInput, UpdateSourceTrigger=PropertyChanged}" 
                                     Style="{StaticResource ModernTextBoxStyle}" Tag="Paste URL and press Enter or click ▶" FontSize="13" Margin="0,0,10,0"/>
                            <Button Grid.Column="1" Content="▶ Download" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding QuickDownloadCommand}" FontSize="12" Padding="16,8"/>
                        </Grid>
                    </Border>

                    <!-- Download List -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" HorizontalScrollBarVisibility="Disabled" Padding="12,8">
                        <ItemsControl ItemsSource="{Binding FilteredDownloads}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="ItemBorder" Background="{StaticResource SurfaceBrush}" CornerRadius="10" Padding="16,12" Margin="4,4"
                                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1">
                                        <Border.ContextMenu>
                                            <ContextMenu Background="{StaticResource SurfaceHighlightBrush}" BorderBrush="{StaticResource BorderSubtleBrush}" Foreground="{StaticResource TextPrimaryBrush}">
                                                <MenuItem Header="⏸ Pause" Command="{Binding DataContext.PauseDownloadCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                                                <MenuItem Header="▶ Resume" Command="{Binding DataContext.ResumeDownloadCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                                                <MenuItem Header="🚫 Cancel" Command="{Binding DataContext.CancelDownloadCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                                                <Separator/>
                                                <MenuItem Header="📂 Open Folder" Command="{Binding DataContext.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                                                <MenuItem Header="📄 Open File" Command="{Binding DataContext.OpenFileCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                                                <MenuItem Header="🔗 Copy URL" Command="{Binding DataContext.CopyUrlCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                                                <Separator/>
                                                <MenuItem Header="🔄 Retry" Command="{Binding DataContext.RetryDownloadCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                                                <MenuItem Header="🗑 Remove" Command="{Binding DataContext.RemoveDownloadCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}"/>
                                                <MenuItem Header="🗑 Remove + Delete File" Command="{Binding DataContext.RemoveWithFileCommand, RelativeSource={RelativeSource AncestorType=Window}}" CommandParameter="{Binding}" Foreground="#FF5252"/>
                                            </ContextMenu>
                                        </Border.ContextMenu>
                                        <Grid>
                                            <Grid.ColumnDefinitions>
                                                <ColumnDefinition Width="Auto"/>
                                                <ColumnDefinition Width="*"/>
                                                <ColumnDefinition Width="90"/>
                                                <ColumnDefinition Width="80"/>
                                                <ColumnDefinition Width="70"/>
                                                <ColumnDefinition Width="110"/>
                                                <ColumnDefinition Width="Auto"/>
                                            </Grid.ColumnDefinitions>

                                            <!-- Category Icon -->
                                            <TextBlock Grid.Column="0" Text="{Binding Category, Converter={StaticResource CategoryIcon}}" FontSize="22" VerticalAlignment="Center" Margin="0,0,12,0"/>

                                            <!-- File Info -->
                                            <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,12,0">
                                                <TextBlock Text="{Binding FileName}" Foreground="{StaticResource TextPrimaryBrush}" FontSize="13" FontWeight="Medium" TextTrimming="CharacterEllipsis" Margin="0,0,0,5"/>
                                                <ProgressBar Value="{Binding ProgressPercentage}" Style="{StaticResource ModernProgressBarStyle}" Maximum="100"/>
                                            </StackPanel>

                                            <!-- Size -->
                                            <TextBlock Grid.Column="2" Text="{Binding TotalSizeFormatted}" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="12" Margin="0,0,10,0"/>

                                            <!-- Speed -->
                                            <TextBlock Grid.Column="3" Text="{Binding Speed}" Foreground="{StaticResource AccentBrush}" VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="12" FontWeight="Medium" Margin="0,0,10,0"/>

                                            <!-- ETA -->
                                            <TextBlock Grid.Column="4" Text="{Binding Eta}" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="11" Margin="0,0,10,0"/>

                                            <!-- Status -->
                                            <TextBlock Grid.Column="5" Text="{Binding Status, Converter={StaticResource StateText}}" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" HorizontalAlignment="Right" FontSize="12" FontWeight="Medium" Margin="0,0,8,0"/>

                                            <!-- Progress % -->
                                            <TextBlock Grid.Column="6" Text="{Binding ProgressText}" Foreground="{StaticResource TextMutedBrush}" VerticalAlignment="Center" FontSize="11" Width="42" TextAlignment="Right"/>
                                        </Grid>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <Trigger SourceName="ItemBorder" Property="IsMouseOver" Value="True">
                                            <Setter TargetName="ItemBorder" Property="Background" Value="{StaticResource SurfaceHighlightBrush}"/>
                                            <Setter TargetName="ItemBorder" Property="BorderBrush" Value="{StaticResource AccentBrush}"/>
                                        </Trigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Empty State -->
                    <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center" 
                                Visibility="{Binding FilteredDownloads.Count, Converter={StaticResource BoolVis}, ConverterParameter=inverse, FallbackValue=Collapsed}">
                        <TextBlock Text="⚡" FontSize="48" HorizontalAlignment="Center" Opacity="0.3" Margin="0,0,0,12"/>
                        <TextBlock Text="No downloads yet" Foreground="{StaticResource TextMutedBrush}" FontSize="16" HorizontalAlignment="Center"/>
                        <TextBlock Text="Paste a URL above or click Add Download" Foreground="{StaticResource TextMutedBrush}" FontSize="12" HorizontalAlignment="Center" Margin="0,6,0,0" Opacity="0.6"/>
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- ═══ STATUS BAR ═══ -->
            <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}" CornerRadius="0,0,12,12" Padding="16,8" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,1,0,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                        <TextBlock Text="⬇" Foreground="{StaticResource AccentBrush}" FontSize="12" VerticalAlignment="Center" Margin="0,0,4,0"/>
                        <TextBlock Text="{Binding CurrentTotalSpeed}" Foreground="{StaticResource AccentBrush}" FontSize="12" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,20,0"/>
                        <TextBlock Foreground="{StaticResource TextMutedBrush}" FontSize="11" VerticalAlignment="Center" Margin="0,0,20,0">
                            <Run Text="Active: "/><Run Text="{Binding ActiveCount}" Foreground="{StaticResource AccentBrush}"/>
                        </TextBlock>
                        <TextBlock Foreground="{StaticResource TextMutedBrush}" FontSize="11" VerticalAlignment="Center">
                            <Run Text="Completed: "/><Run Text="{Binding CompletedCount}" Foreground="{StaticResource SuccessBrush}"/>
                        </TextBlock>
                    </StackPanel>
                    <TextBlock HorizontalAlignment="Right" Foreground="{StaticResource TextMutedBrush}" FontSize="11" VerticalAlignment="Center">
                        <Run Text="Total: "/><Run Text="{Binding TotalDownloaded}"/>
                    </TextBlock>
                </Grid>
            </Border>

            <!-- ═══ ADD DOWNLOAD DIALOG OVERLAY ═══ -->
            <Border Grid.Row="0" Grid.RowSpan="3" Background="#80000000" Visibility="{Binding IsAddDialogOpen, Converter={StaticResource BoolVis}}" CornerRadius="12">
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="14" Width="520" VerticalAlignment="Center" HorizontalAlignment="Center"
                        BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" Effect="{StaticResource CardShadow}">
                    <StackPanel Margin="28,24">
                        <Grid Margin="0,0,0,20">
                            <TextBlock Text="Add New Download" Foreground="{StaticResource TextPrimaryBrush}" FontSize="18" FontWeight="SemiBold"/>
                            <Button Content="✕" Style="{StaticResource IconButtonStyle}" HorizontalAlignment="Right" Command="{Binding CloseAddDialogCommand}"/>
                        </Grid>

                        <TextBlock Text="URL" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,6" FontWeight="Medium"/>
                        <TextBox Text="{Binding DialogUrl, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}" Tag="https://example.com/file.zip" Margin="0,0,0,14"/>

                        <TextBlock Text="FILE NAME" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,6" FontWeight="Medium"/>
                        <TextBox Text="{Binding DialogFileName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}" Tag="Auto-detect from URL" Margin="0,0,0,14"/>

                        <TextBlock Text="SAVE TO" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,6" FontWeight="Medium"/>
                        <Grid Margin="0,0,0,14">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding DialogSavePath, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}" Tag="Download folder" Margin="0,0,8,0"/>
                            <Button Grid.Column="1" Content="📂" Style="{StaticResource GhostButtonStyle}" Command="{Binding SelectSaveFolderCommand}" Padding="10,8" FontSize="16"/>
                        </Grid>

                        <Grid Margin="0,0,0,18">
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="*"/>
                            </Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0" Margin="0,0,8,0">
                                <TextBlock Text="SEGMENTS" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,6" FontWeight="Medium"/>
                                <TextBox Text="{Binding DialogSegmentCount, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}" Tag="16"/>
                            </StackPanel>
                            <StackPanel Grid.Column="1" Margin="8,0,0,0">
                                <TextBlock Text="SCHEDULE" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" Margin="0,0,0,6" FontWeight="Medium"/>
                                <CheckBox Content="Schedule later" IsChecked="{Binding DialogScheduleEnabled}" Style="{StaticResource ModernCheckBoxStyle}" Margin="0,6,0,0"/>
                            </StackPanel>
                        </Grid>

                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="Cancel" Style="{StaticResource GhostButtonStyle}" Command="{Binding CloseAddDialogCommand}" Padding="16,10" HorizontalAlignment="Left"/>
                            <Button Grid.Column="1" Content="⬇ Start Download" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding ConfirmAddDownloadCommand}"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Border>

        </Grid>
    </Border>
</Window>
