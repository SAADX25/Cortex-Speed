<Window x:Class="CortexSpeed.Presentation.WPF.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:vm="clr-namespace:CortexSpeed.Presentation.WPF.ViewModels"
        xmlns:conv="clr-namespace:CortexSpeed.Presentation.WPF.Converters"
        d:DataContext="{d:DesignInstance Type=vm:MainViewModel}"
        mc:Ignorable="d"
        Title="Cortex Speed" Height="740" Width="1120" MinHeight="580" MinWidth="860"
        Background="{StaticResource AppBackgroundBrush}"
        WindowStartupLocation="CenterScreen"
        WindowStyle="None" AllowsTransparency="True"
        FontFamily="Segoe UI, Inter, Arial">

    <WindowChrome.WindowChrome>
        <WindowChrome CaptionHeight="38" GlassFrameThickness="0" CornerRadius="12" ResizeBorderThickness="6"/>
    </WindowChrome.WindowChrome>

    <Window.Resources>
        <conv:CategoryToIconConverter       x:Key="CategoryIcon"/>
        <conv:DownloadStateConverter        x:Key="StateText"/>
        <conv:DownloadStateToBrushConverter x:Key="StateBrush"/>
        <conv:DownloadStateToColorConverter x:Key="StateColor"/>
        <conv:BoolToVisibilityConverter     x:Key="BoolVis"/>
        <conv:NavItemIconConverter          x:Key="NavIcon"/>
        <conv:NavItemVisibilityConverter    x:Key="NavVis"/>
        <conv:NavSeparatorVisibilityConverter x:Key="NavSep"/>
        <conv:CountToVisibilityConverter    x:Key="CountVis"/>
        <conv:IsDownloadingConverter        x:Key="IsDownloading"/>
        <conv:IsPausedConverter             x:Key="IsPaused"/>
        <conv:IsCompletedConverter          x:Key="IsCompleted"/>
    </Window.Resources>

    <Border CornerRadius="12" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
            Background="{StaticResource AppBackgroundBrush}">
        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="38"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ═══ TITLE BAR ═══ -->
            <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}" CornerRadius="12,12,0,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center" Margin="14,0">
                        <Border Width="22" Height="22" CornerRadius="6" Margin="0,0,9,0">
                            <Border.Background>
                                <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                    <GradientStop Color="#00E5C4" Offset="0"/>
                                    <GradientStop Color="#7C5CE7" Offset="1"/>
                                </LinearGradientBrush>
                            </Border.Background>
                            <TextBlock Text="⚡" FontSize="11" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="White"/>
                        </Border>
                        <TextBlock Text="Cortex Speed" Foreground="{StaticResource TextPrimaryBrush}" FontWeight="SemiBold" FontSize="13" VerticalAlignment="Center"/>
                        <Border Background="{StaticResource SurfaceHighlightBrush}" CornerRadius="4" Padding="5,2" Margin="8,0" VerticalAlignment="Center">
                            <TextBlock Text="v4.0" Foreground="{StaticResource TextMutedBrush}" FontSize="9"/>
                        </Border>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                        <Button Style="{StaticResource WindowChromeButton}" Click="MinimizeClick">
                            <TextBlock Text="&#xE921;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="10"/>
                        </Button>
                        <Button Style="{StaticResource WindowChromeButton}" Click="MaximizeClick">
                            <TextBlock Text="&#xE922;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="10"/>
                        </Button>
                        <Button Style="{StaticResource WindowCloseButton}" Click="CloseClick">
                            <TextBlock Text="&#xE8BB;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="10"/>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ═══ BODY ═══ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="210"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ═══ SIDEBAR ═══ -->
                <Border Grid.Column="0" Background="{StaticResource SidebarGradientBrush}"
                        BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,1,0">
                    <DockPanel>
                        <!-- Add Download -->
                        <Button DockPanel.Dock="Top" Style="{StaticResource PrimaryButtonStyle}"
                                Margin="12,14,12,6" Padding="0,11"
                                Command="{Binding AddDownload.OpenCommand}">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE710;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="15" Margin="0,0,7,0" VerticalAlignment="Center"/>
                                <TextBlock Text="New Download" FontSize="12.5" VerticalAlignment="Center" FontWeight="Bold"/>
                            </StackPanel>
                        </Button>

                        <!-- Bottom controls -->
                        <StackPanel DockPanel.Dock="Bottom" Margin="10,6,10,14">
                            <Button Style="{StaticResource GhostButtonStyle}" HorizontalAlignment="Stretch" Command="{Binding Settings.OpenCommand}">
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <TextBlock Text="&#xE713;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="15" Margin="0,0,8,0" VerticalAlignment="Center"/>
                                    <TextBlock Text="Settings" FontSize="13" VerticalAlignment="Center"/>
                                </StackPanel>
                            </Button>
                        </StackPanel>

                        <!-- Single unified nav list -->
                        <ListBox ItemsSource="{Binding SidebarItems}" SelectedItem="{Binding SelectedCategory}"
                                 Background="Transparent" BorderThickness="0" Margin="0,6,0,0"
                                 ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                                 ItemContainerStyle="{StaticResource SidebarItemStyle}">
                            <ListBox.ItemTemplate>
                                <DataTemplate>
                                    <Grid>
                                        <!-- Separator line (visible only for ─── items) -->
                                        <Border Visibility="{Binding Converter={StaticResource NavSep}}"
                                                Height="1" Background="{StaticResource BorderSubtleBrush}"
                                                Margin="4,4"/>
                                        <!-- Nav item content (hidden for ─── items) -->
                                        <StackPanel Orientation="Horizontal"
                                                    Visibility="{Binding Converter={StaticResource NavVis}}">
                                            <TextBlock Text="{Binding Converter={StaticResource NavIcon}}"
                                                       FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                       Width="20" FontSize="15"
                                                       HorizontalAlignment="Center" VerticalAlignment="Center"
                                                       Margin="0,0,8,0"/>
                                            <TextBlock Text="{Binding}" FontSize="12.5" VerticalAlignment="Center"/>
                                        </StackPanel>
                                    </Grid>
                                </DataTemplate>
                            </ListBox.ItemTemplate>
                        </ListBox>
                    </DockPanel>
                </Border>

                <!-- ═══ RIGHT PANEL ═══ -->
                <Grid Grid.Column="1">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>

                    <!-- URL bar -->
                    <Border Grid.Row="0" Background="{StaticResource SurfaceBrush}"
                            Padding="14,10" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,0,0,1">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <Border Grid.Column="0" Background="{StaticResource SurfaceHighlightBrush}"
                                    BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1"
                                    CornerRadius="9" Margin="0,0,10,0">
                                <Grid>
                                    <TextBlock Text="🔗" FontSize="12" VerticalAlignment="Center" Margin="13,0" Foreground="{StaticResource TextMutedBrush}"/>
                                    <TextBox Text="{Binding UrlInput, UpdateSourceTrigger=PropertyChanged}"
                                             Style="{StaticResource ModernTextBoxStyle}"
                                             Tag="Paste a download URL and press Enter…"
                                             FontSize="12.5" Padding="34,10,14,10"
                                             Background="Transparent" BorderThickness="0"/>
                                </Grid>
                            </Border>
                            <Button Grid.Column="1" Style="{StaticResource PrimaryButtonStyle}"
                                    Command="{Binding QuickDownloadCommand}" Padding="18,10">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="▶" Margin="0,0,6,0"/>
                                    <TextBlock Text="Download" FontWeight="Bold"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </Border>

                    <!-- Download cards -->
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto"
                                  HorizontalScrollBarVisibility="Disabled" Padding="12,8">
                        <ItemsControl ItemsSource="{Binding FilteredDownloads}">
                            <ItemsControl.ItemTemplate>
                                <DataTemplate>
                                    <Border x:Name="Card" CornerRadius="14" Margin="4,5" Padding="18,16,18,14"
                                            Background="{StaticResource SurfaceBrush}"
                                            BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1">

                                        <Grid>
                                            <Grid.RowDefinitions>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                                <RowDefinition Height="Auto"/>
                                            </Grid.RowDefinitions>

                                            <!-- Row 1: icon + info + status/actions -->
                                            <Grid Grid.Row="0">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>

                                                <!-- Category icon -->
                                                <Border Grid.Column="0" Width="44" Height="44" CornerRadius="12"
                                                        VerticalAlignment="Center" Margin="0,0,14,0">
                                                    <Border.Background>
                                                        <LinearGradientBrush StartPoint="0,0" EndPoint="1,1">
                                                            <GradientStop Color="#111820" Offset="0"/>
                                                            <GradientStop Color="#182030" Offset="1"/>
                                                        </LinearGradientBrush>
                                                    </Border.Background>
                                                    <TextBlock Text="{Binding Category, Converter={StaticResource CategoryIcon}}"
                                                               FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                                               FontSize="18" HorizontalAlignment="Center" VerticalAlignment="Center"
                                                               Foreground="{StaticResource AccentBrush}"/>
                                                </Border>

                                                <!-- Filename + URL -->
                                                <StackPanel Grid.Column="1" VerticalAlignment="Center" Margin="0,0,12,0">
                                                    <TextBlock Text="{Binding FileName}"
                                                               Foreground="{StaticResource TextPrimaryBrush}"
                                                               FontSize="14" FontWeight="SemiBold"
                                                               TextTrimming="CharacterEllipsis"/>
                                                    <TextBlock Text="{Binding Url}"
                                                               Foreground="{StaticResource TextMutedBrush}"
                                                               FontSize="10.5" TextWrapping="NoWrap"
                                                               TextTrimming="CharacterEllipsis"
                                                               Margin="0,3,0,0" MaxWidth="400"/>
                                                </StackPanel>

                                                <!-- Status badge (always visible) -->
                                                <Border x:Name="StatusBadge" Grid.Column="2" CornerRadius="8" Padding="10,5"
                                                        VerticalAlignment="Center" Margin="0,0,8,0">
                                                    <Border.Background>
                                                        <SolidColorBrush Color="#12161E"/>
                                                    </Border.Background>
                                                    <StackPanel Orientation="Horizontal">
                                                        <Ellipse Width="7" Height="7" VerticalAlignment="Center"
                                                                 Fill="{Binding Status, Converter={StaticResource StateBrush}}" Margin="0,0,6,0"/>
                                                        <TextBlock Text="{Binding Status, Converter={StaticResource StateText}}"
                                                                   Foreground="{Binding Status, Converter={StaticResource StateColor}}"
                                                                   FontSize="11" FontWeight="SemiBold"/>
                                                    </StackPanel>
                                                </Border>

                                                <!-- Action buttons -->
                                                <StackPanel x:Name="ActionPanel" Grid.Column="3" Orientation="Horizontal"
                                                            Opacity="0" IsHitTestVisible="False" VerticalAlignment="Center">
                                                    <Button Style="{StaticResource IconButtonStyle}" ToolTip="Pause" Margin="0,0,2,0"
                                                            Visibility="{Binding Status, Converter={StaticResource IsDownloading}}"
                                                            Command="{Binding DataContext.PauseDownloadCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}">
                                                        <TextBlock Text="&#xE769;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="13"/>
                                                    </Button>
                                                    <Button Style="{StaticResource IconButtonStyle}" ToolTip="Resume" Margin="0,0,2,0"
                                                            Visibility="{Binding Status, Converter={StaticResource IsPaused}}"
                                                            Command="{Binding DataContext.ResumeDownloadCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}">
                                                        <TextBlock Text="&#xE768;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="13"/>
                                                    </Button>
                                                    <Button Style="{StaticResource IconButtonStyle}" ToolTip="Open File" Margin="0,0,2,0"
                                                            Visibility="{Binding Status, Converter={StaticResource IsCompleted}}"
                                                            Command="{Binding DataContext.OpenFileCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}">
                                                        <TextBlock Text="&#xE8E5;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="13"/>
                                                    </Button>
                                                    <Button Style="{StaticResource IconButtonStyle}" ToolTip="Open Folder" Margin="0,0,2,0"
                                                            Visibility="{Binding Status, Converter={StaticResource IsCompleted}}"
                                                            Command="{Binding DataContext.OpenFolderCommand, RelativeSource={RelativeSource AncestorType=Window}}"
                                                            CommandParameter="{Binding}">
                                                        <TextBlock Text="&#xE838;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="13"/>
                                                    </Button>
                                                    <Button Style="{StaticResource IconButtonStyle}" ToolTip="Remove"
                                                            Tag="{Binding}"
                                                            Click="OpenDeleteMenu_Click">
                                                        <TextBlock Text="&#xE74D;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets" FontSize="13"/>
                                                    </Button>
                                                </StackPanel>
                                            </Grid>

                                            <!-- Progress bar -->
                                            <Grid Grid.Row="1" Margin="0,12,0,10">
                                                <ProgressBar Value="{Binding ProgressPercentage}"
                                                             Style="{StaticResource ModernProgressBarStyle}"
                                                             Height="5" Maximum="100"/>
                                            </Grid>

                                            <!-- Row 3: stats -->
                                            <Grid Grid.Row="2">
                                                <Grid.ColumnDefinitions>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                    <ColumnDefinition Width="*"/>
                                                    <ColumnDefinition Width="Auto"/>
                                                </Grid.ColumnDefinitions>
                                                
                                                <TextBlock Grid.Column="0" Foreground="{StaticResource TextSecondaryBrush}" FontSize="11" VerticalAlignment="Center" Margin="0,0,14,0">
                                                    <Run Text="{Binding DownloadedSizeFormatted, Mode=OneWay}"/>
                                                    <Run Text="/" Foreground="{StaticResource TextMutedBrush}"/>
                                                    <Run Text="{Binding TotalSizeFormatted, Mode=OneWay}"/>
                                                </TextBlock>

                                                <Border Grid.Column="1" CornerRadius="4" Padding="7,2" Margin="0,0,10,0"
                                                        VerticalAlignment="Center" Background="#0D1118">
                                                    <TextBlock Text="{Binding Speed}" Foreground="{StaticResource AccentBrush}"
                                                               FontSize="11" FontWeight="SemiBold"/>
                                                </Border>

                                                <TextBlock Grid.Column="2" Text="{Binding Eta}"
                                                           Foreground="{StaticResource TextMutedBrush}" FontSize="11" VerticalAlignment="Center"/>

                                                <TextBlock Grid.Column="4" Text="{Binding ProgressText}"
                                                           Foreground="{StaticResource TextPrimaryBrush}" FontSize="12.5"
                                                           FontWeight="Bold" VerticalAlignment="Center"/>
                                            </Grid>
                                        </Grid>
                                    </Border>
                                    <DataTemplate.Triggers>
                                        <Trigger SourceName="Card" Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Card" Property="Background" Value="{StaticResource SurfaceHoverBrush}"/>
                                            <Setter TargetName="Card" Property="BorderBrush" Value="{StaticResource BorderMediumBrush}"/>
                                            <Setter TargetName="ActionPanel" Property="IsHitTestVisible" Value="True"/>
                                        </Trigger>
                                        
                                        <EventTrigger RoutedEvent="MouseEnter" SourceName="Card">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="ActionPanel" Storyboard.TargetProperty="Opacity" To="1" Duration="0:0:0.15"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                        
                                        <EventTrigger RoutedEvent="MouseLeave" SourceName="Card">
                                            <BeginStoryboard>
                                                <Storyboard>
                                                    <DoubleAnimation Storyboard.TargetName="ActionPanel" Storyboard.TargetProperty="Opacity" To="0" Duration="0:0:0.1"/>
                                                </Storyboard>
                                            </BeginStoryboard>
                                        </EventTrigger>
                                    </DataTemplate.Triggers>
                                </DataTemplate>
                            </ItemsControl.ItemTemplate>
                        </ItemsControl>
                    </ScrollViewer>

                    <!-- Empty state -->
                    <StackPanel Grid.Row="1" VerticalAlignment="Center" HorizontalAlignment="Center"
                                Visibility="{Binding FilteredDownloads.Count, Converter={StaticResource CountVis}, FallbackValue=Collapsed}">
                        <Border Width="72" Height="72" CornerRadius="20" HorizontalAlignment="Center" Margin="0,0,0,16" Opacity="0.4">
                            <Border.Background><LinearGradientBrush StartPoint="0,0" EndPoint="1,1"><GradientStop Color="#0F1620" Offset="0"/><GradientStop Color="#1A2034" Offset="1"/></LinearGradientBrush></Border.Background>
                            <TextBlock Text="⚡" FontSize="36" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="No downloads yet" Foreground="{StaticResource TextSecondaryBrush}" FontSize="15" HorizontalAlignment="Center" FontWeight="Medium"/>
                        <TextBlock Text="Paste a URL above or click New Download" Foreground="{StaticResource TextMutedBrush}" FontSize="12" HorizontalAlignment="Center" Margin="0,5,0,0"/>
                    </StackPanel>
                </Grid>
            </Grid>

            <!-- ═══ STATUS BAR ═══ -->
            <Border Grid.Row="2" Background="{StaticResource SurfaceBrush}"
                    CornerRadius="0,0,12,12" Padding="18,7"
                    BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="0,1,0,0">
                <Grid>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <Ellipse Width="7" Height="7" Fill="{StaticResource AccentBrush}" VerticalAlignment="Center" Margin="0,0,6,0"/>
                        <TextBlock Text="{Binding CurrentTotalSpeed}" Foreground="{StaticResource AccentBrush}" FontSize="11.5" FontWeight="SemiBold" VerticalAlignment="Center" Margin="0,0,20,0"/>
                        <TextBlock Foreground="{StaticResource TextMutedBrush}" FontSize="11" VerticalAlignment="Center" Margin="0,0,16,0">
                            <Run Text="Active: "/><Run Text="{Binding ActiveCount}" Foreground="{StaticResource AccentBrush}" FontWeight="Bold"/>
                        </TextBlock>
                        <TextBlock Foreground="{StaticResource TextMutedBrush}" FontSize="11" VerticalAlignment="Center">
                            <Run Text="Done: "/><Run Text="{Binding CompletedCount}" Foreground="{StaticResource SuccessBrush}" FontWeight="Bold"/>
                        </TextBlock>
                    </StackPanel>
                    <TextBlock HorizontalAlignment="Right" Foreground="{StaticResource TextMutedBrush}" FontSize="11" VerticalAlignment="Center">
                        <Run Text="Total downloaded: "/><Run Text="{Binding TotalDownloaded}" Foreground="{StaticResource TextSecondaryBrush}"/>
                    </TextBlock>
                </Grid>
            </Border>

            <!-- ═══ DELETE POPUP (inside window) ═══ -->
            <Popup x:Name="DeletePopup" Grid.Row="0" Grid.RowSpan="3"
                   AllowsTransparency="True" Placement="MousePoint"
                   StaysOpen="False">
                <Border Background="#181C24" CornerRadius="10" Padding="6"
                        BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="1">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="20" ShadowDepth="4" Opacity="0.6" Color="#000000" Direction="270"/>
                    </Border.Effect>
                    <StackPanel MinWidth="200">
                        <!-- Remove from list -->
                        <Button x:Name="RemoveFromListBtn" Style="{StaticResource GhostButtonStyle}"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                Padding="12,9" Click="RemoveFromList_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE738;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           FontSize="13" Foreground="{StaticResource TextSecondaryBrush}" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="Remove from list" FontSize="12.5" Foreground="{StaticResource TextPrimaryBrush}" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                        <!-- Separator -->
                        <Border Height="1" Background="{StaticResource BorderSubtleBrush}" Margin="8,3"/>
                        <!-- Delete from disk -->
                        <Button x:Name="DeleteFromDiskBtn" Style="{StaticResource GhostButtonStyle}"
                                HorizontalAlignment="Stretch" HorizontalContentAlignment="Left"
                                Padding="12,9" Click="DeleteFromDisk_Click">
                            <StackPanel Orientation="Horizontal">
                                <TextBlock Text="&#xE74D;" FontFamily="Segoe Fluent Icons, Segoe MDL2 Assets"
                                           FontSize="13" Foreground="#FF4D6A" VerticalAlignment="Center" Margin="0,0,10,0"/>
                                <TextBlock Text="Delete from disk" FontSize="12.5" Foreground="#FF4D6A" VerticalAlignment="Center"/>
                            </StackPanel>
                        </Button>
                    </StackPanel>
                </Border>
            </Popup>

            <!-- ═══ ADD DOWNLOAD DIALOG ═══ -->
            <Border x:Name="AddDialogBackground" Grid.Row="0" Grid.RowSpan="3" CornerRadius="12"
                    Visibility="{Binding AddDownload.IsOpen, Converter={StaticResource BoolVis}}"
                    MouseLeftButtonDown="CloseDialogOnBackgroundClick">
                <Border.Background><SolidColorBrush Color="#000000" Opacity="0.72"/></Border.Background>
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="14"
                        Width="500" VerticalAlignment="Center" HorizontalAlignment="Center"
                        BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="1"
                        Effect="{StaticResource DialogShadow}"
                        MouseLeftButtonDown="DialogContent_MouseLeftButtonDown">
                    <StackPanel Margin="28,22,28,24">
                        <!-- Header -->
                        <Grid Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="New Download" Foreground="{StaticResource TextPrimaryBrush}" FontSize="17" FontWeight="SemiBold"/>
                                <TextBlock Text="Configure and start your download" Foreground="{StaticResource TextMutedBrush}" FontSize="11.5" Margin="0,3,0,0"/>
                            </StackPanel>
                            <Button Style="{StaticResource IconButtonStyle}" HorizontalAlignment="Right" VerticalAlignment="Top" Command="{Binding AddDownload.CloseCommand}">
                                <TextBlock Text="✕" FontSize="13" Foreground="{StaticResource TextMutedBrush}"/>
                            </Button>
                        </Grid>

                        <TextBlock Text="URL" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10.5" Margin="0,0,0,5" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding AddDownload.Url, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}" Tag="https://example.com/file.zip" Margin="0,0,0,14"/>

                        <TextBlock Text="FILE NAME" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10.5" Margin="0,0,0,5" FontWeight="SemiBold"/>
                        <TextBox Text="{Binding AddDownload.FileName, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}" Tag="Auto-detected from URL" Margin="0,0,0,14"/>

                        <TextBlock Text="SAVE TO" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10.5" Margin="0,0,0,5" FontWeight="SemiBold"/>
                        <Grid Margin="0,0,0,16">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <TextBox Grid.Column="0" Text="{Binding AddDownload.SavePath, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}" Tag="Download folder" Margin="0,0,8,0"/>
                            <Button Grid.Column="1" Style="{StaticResource GhostButtonStyle}" Command="{Binding AddDownload.SelectSaveFolderCommand}" Padding="11,9" ToolTip="Browse folder">
                                <TextBlock Text="📂" FontSize="15"/>
                            </Button>
                        </Grid>

                        <Grid Margin="0,0,0,20">
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="14"/><ColumnDefinition Width="*"/></Grid.ColumnDefinitions>
                            <StackPanel Grid.Column="0">
                                <TextBlock Text="SEGMENTS" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10.5" Margin="0,0,0,5" FontWeight="SemiBold"/>
                                <TextBox Text="{Binding AddDownload.SegmentCount, UpdateSourceTrigger=PropertyChanged}" Style="{StaticResource ModernTextBoxStyle}" Tag="16"/>
                            </StackPanel>
                            <StackPanel Grid.Column="2">
                                <TextBlock Text="SCHEDULE" Foreground="{StaticResource TextSecondaryBrush}" FontSize="10.5" Margin="0,0,0,5" FontWeight="SemiBold"/>
                                <Border Background="{StaticResource SurfaceHighlightBrush}" BorderBrush="{StaticResource BorderSubtleBrush}" BorderThickness="1" CornerRadius="8" Padding="12,10">
                                    <CheckBox Content="Schedule later" IsChecked="{Binding AddDownload.ScheduleEnabled}" Style="{StaticResource ModernCheckBoxStyle}" Foreground="{StaticResource TextSecondaryBrush}"/>
                                </Border>
                            </StackPanel>
                        </Grid>

                        <Border Height="1" Background="{StaticResource BorderSubtleBrush}" Margin="0,0,0,18"/>

                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="Cancel" Style="{StaticResource GhostButtonStyle}" Command="{Binding AddDownload.CloseCommand}" Padding="18,10" HorizontalAlignment="Left"/>
                            <Button Grid.Column="1" Style="{StaticResource PrimaryButtonStyle}" Command="{Binding AddDownload.ConfirmAddDownloadCommand}" Padding="24,11">
                                <StackPanel Orientation="Horizontal">
                                    <TextBlock Text="⬇" Margin="0,0,7,0"/>
                                    <TextBlock Text="Start Download" FontWeight="Bold"/>
                                </StackPanel>
                            </Button>
                        </Grid>
                    </StackPanel>
                </Border>
            </Border>

            <!-- ═══ SETTINGS PANEL ═══ -->
            <Border Grid.Row="0" Grid.RowSpan="3" CornerRadius="12"
                    Visibility="{Binding Settings.IsOpen, Converter={StaticResource BoolVis}}"
                    MouseLeftButtonDown="CloseSettingsOnBackgroundClick">
                <Border.Background><SolidColorBrush Color="#000000" Opacity="0.72"/></Border.Background>
                <Border Background="{StaticResource SurfaceBrush}" CornerRadius="14"
                        Width="500" VerticalAlignment="Center" HorizontalAlignment="Center"
                        BorderBrush="{StaticResource BorderMediumBrush}" BorderThickness="1"
                        Effect="{StaticResource DialogShadow}"
                        MouseLeftButtonDown="SettingsContent_MouseLeftButtonDown">
                    <StackPanel Margin="28,22,28,24">
                        <!-- Header -->
                        <Grid Margin="0,0,0,20">
                            <StackPanel>
                                <TextBlock Text="Settings" Foreground="{StaticResource TextPrimaryBrush}" FontSize="17" FontWeight="SemiBold"/>
                                <TextBlock Text="Customize Cortex Speed" Foreground="{StaticResource TextMutedBrush}" FontSize="11.5" Margin="0,3,0,0"/>
                            </StackPanel>
                            <Button Style="{StaticResource IconButtonStyle}" HorizontalAlignment="Right" VerticalAlignment="Top" Command="{Binding Settings.CloseCommand}">
                                <TextBlock Text="✕" FontSize="13" Foreground="{StaticResource TextMutedBrush}"/>
                            </Button>
                        </Grid>

                        <TextBlock Text="Coming soon..." Foreground="{StaticResource TextMutedBrush}" FontSize="13" HorizontalAlignment="Center" VerticalAlignment="Center" Margin="0,40"/>

                        <Border Height="1" Background="{StaticResource BorderSubtleBrush}" Margin="0,40,0,18"/>

                        <Grid>
                            <Grid.ColumnDefinitions><ColumnDefinition Width="*"/><ColumnDefinition Width="Auto"/></Grid.ColumnDefinitions>
                            <Button Grid.Column="0" Content="Cancel" Style="{StaticResource GhostButtonStyle}" Command="{Binding Settings.CloseCommand}" Padding="18,10" HorizontalAlignment="Left"/>
                        </Grid>
                    </StackPanel>
                </Border>
            </Border>

        </Grid>
    </Border>
</Window>
